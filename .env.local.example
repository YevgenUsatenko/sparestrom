# Database (Supabase Postgres, EU-Region Frankfurt)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=[ANON_KEY]

# Resend (Transaktions-Mails)
RESEND_API_KEY=re_[API_KEY]

# IBAN-Verschlüsselung (AES-256-CBC, 64 hex chars)
ENCRYPTION_KEY=[64_HEX_CHARS]

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sparestrom.at

# App
NEXT_PUBLIC_BASE_URL=https://sparestrom.at
